    {{#with page.canonicalUrl}}
    <meta property="og:url" content="{{{this}}}">
    {{/with}}
    {{#if page.home}}
    <meta property="og:type" content="website">
    {{else}}
    <meta property="og:type" content="article">
    {{/if}}
    <meta property="og:site_name" content="{{{detag site.title attribute=true}}}">
    {{#if (eq (or page.title defaultPageTitle) site.title)}}
    <meta property="og:title" content="{{{detag site.title attribute=true}}} Documentation">
    <meta name="twitter:title" content="{{{detag site.title attribute=true}}} Documentation">
    {{else}}
    <meta property="og:title" content="{{{detag (or page.title defaultPageTitle) attribute=true}}}">
    <meta name="twitter:title" content="{{{detag (or page.title defaultPageTitle) attribute=true}}}">
    {{/if}}
    {{#with page.description}}
    <meta property="og:description" content="{{{detag this attribute=true}}}">
    <meta name="twitter:description" content="{{{detag this attribute=true}}}">
    {{/with}}
    <meta name="twitter:card" content="summary">
